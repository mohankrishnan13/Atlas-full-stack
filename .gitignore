.env
# ══════════════════════════════════════════════════════════════════════════════
# ATLAS Backend — .gitignore
#
# Rule of thumb: if it contains secrets, is generated, or is machine-specific,
# it does not belong in the repository.
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & secrets ─────────────────────────────────────────────────────
# NEVER commit .env — it contains real passwords and API keys.
.env
.env.*
!.env.example        # .env.example is safe — it contains no real values

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.cache/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ── mypy / type checkers ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
# Ignore local override files that may contain dev-only secrets
docker-compose.override.yml
docker-compose.local.yml

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres_data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
# Keep the data/logs directory structure but ignore actual log content
data/logs/**/*.log
data/logs/**/*.jsonl
# Retain CSV fixture files used for Pandas dev seeding
!data/logs/**/*.csv
!data/logs/**/*.log_structured.csv
!data/logs/**/*.log_templates.csv
!data/logs/**/README.md

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migration scripts; ignore the generated env.py if it embeds credentials
alembic/versions/*.pyc

# ── Build artefacts ───────────────────────────────────────────────────────────
dist/
*.tar.gz
*.zip

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride




