# ATLAS Backend — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=ATLAS
APP_ENV=development
DEBUG=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Async URL used by SQLAlchemy in FastAPI handlers
DATABASE_URL=postgresql+asyncpg://change:change@postgres:5432/change

# Sync URL used only by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg2://change:change@postgres:5432/change

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO_SQL=false

# ── Log Ingestion ─────────────────────────────────────────────────────────────
LOG_DATA_DIR=data/logs

# Set to false in production to preserve data across restarts
REINGEST_ON_STARTUP=true

# ── Velociraptor ──────────────────────────────────────────────────────────────
# Secret shared between Velociraptor server and this FastAPI backend
# for HMAC-SHA256 webhook signature verification
VELOCIRAPTOR_WEBHOOK_SECRET=change_me_in_production_use_openssl_rand_hex_32
VELOCIRAPTOR_API_URL=https://localhost:8001
VELOCIRAPTOR_API_KEY=

# ── Ollama LLM Copilot (optional) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Security / JWT ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY_FOR_JWT_SIGNING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Risk Thresholds ───────────────────────────────────────────────────────────
RISK_WARN_THRESHOLD=1
RISK_SOFT_LIMIT_THRESHOLD=3
RISK_HARD_BLOCK_THRESHOLD=5
ANOMALY_SCORE_THRESHOLD=-0.1

# ── HTTP Ingest Endpoint (Vector / Fluent Bit) ────────────────────────────────
# Static API key for POST /api/ingest/http
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
INGEST_API_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_48
INGEST_API_KEY_HEADER=X-Atlas-API-Key
INGEST_MAX_BATCH_SIZE=5000

# ── AWS S3 Cold-Storage Ingestion ─────────────────────────────────────────────
# Set S3_ENABLED=true to start the background polling task on startup.
S3_ENABLED=false

# Leave blank to use IAM role / instance profile (recommended in production).
# Only set these for local dev or cross-account access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

S3_LOG_BUCKET=atlas-soc-cold-logs
S3_LOG_PREFIX=logs/

# How often the background task polls for new objects (seconds)
S3_POLL_INTERVAL_SECONDS=300

# Max S3 objects downloaded per poll cycle (prevents overwhelming the DB)
S3_MAX_KEYS_PER_POLL=50


# ── PostgreSQL Container Credentials ─────────────────────────────────────────
# Used by docker-compose for the postgres service
POSTGRES_USER=change
POSTGRES_PASSWORD=change
POSTGRES_DB=change