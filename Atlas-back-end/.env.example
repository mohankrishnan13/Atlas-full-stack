# ══════════════════════════════════════════════════════════════════════════════
# ATLAS SOC Dashboard — Environment Configuration
#
# Copy this file to .env and fill in every value marked REQUIRED.
# NEVER commit .env to version control — add it to .gitignore.
#
# Required vs optional
# ──────────────────────
#   [REQUIRED]  The application will refuse to start without this value.
#   [OPTIONAL]  A safe default exists; override only when necessary.
#   [GENERATE]  Must be generated — do not invent a value by hand.
#
# Quick-start (generate all secrets in one pass):
#   python -c "
#   import secrets
#   print('SECRET_KEY=' + secrets.token_hex(32))
#   print('INGEST_API_KEY=' + secrets.token_urlsafe(48))
#   "
#   openssl rand -hex 32   # → VELOCIRAPTOR_WEBHOOK_SECRET
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ────────────────────────────────────────────────────────────────
# [OPTIONAL] Human-readable service name shown in logs and the /health endpoint.
APP_NAME=ATLAS

# [OPTIONAL] Runtime environment label.  Controls log verbosity and error detail.
#   development | staging | production
APP_ENV=development

# [OPTIONAL] When true: event loop debug, full exception detail in HTTP 500 responses.
#            Set to false before going to production.
DEBUG=true


# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# [REQUIRED] Async SQLAlchemy URL consumed by FastAPI handlers.
#   Format:  postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#   Docker Compose default maps to the postgres service below.
DATABASE_URL=postgresql+asyncpg://atlas_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/atlas_db

# [OPTIONAL] Synchronous URL consumed only by Alembic CLI migrations.
#            Not required at runtime — leave blank if you do not use Alembic.
DATABASE_URL_SYNC=postgresql+psycopg2://atlas_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/atlas_db

# [OPTIONAL] Connection pool tuning — safe defaults suit most deployments.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
# [OPTIONAL] Log every SQL statement — enable only for deep debugging.
DB_ECHO_SQL=false


# ── PostgreSQL Container Credentials ──────────────────────────────────────────
# Used by docker-compose for the 'postgres' service.
# Must match the credentials embedded in DATABASE_URL / DATABASE_URL_SYNC above.
# [REQUIRED]
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=atlas_db


# ── Seed / Bootstrap Accounts ──────────────────────────────────────────────────
# These three accounts are created on first startup when the atlas_users table
# is empty.  Change ALL passwords in .env before the very first boot.
# After the first boot, rotate passwords through the UI — the seed values are
# hashed and stored in the database; changing .env has no effect on existing rows.

# [OPTIONAL] Email address for each role.
SEED_ADMIN_EMAIL=admin@atlas.local
SEED_ANALYST_EMAIL=analyst@atlas.local
SEED_READONLY_EMAIL=audit@atlas.local

# [REQUIRED] Strong, unique password for each account.
#   Minimum recommendation: 16 characters, mixed case + numbers + symbols.
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD
SEED_ANALYST_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD
SEED_READONLY_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD

# [OPTIONAL] Display name for each account.
SEED_ADMIN_NAME=ATLAS Administrator
SEED_ANALYST_NAME=SOC Analyst
SEED_READONLY_NAME=Auditor External


# ── Security / JWT ─────────────────────────────────────────────────────────────
# [REQUIRED] [GENERATE] Secret used to sign and verify all JWT access tokens.
#   Generate: python -c "import secrets; print(secrets.token_hex(32))"
#   Must be kept secret — rotating this key invalidates all active sessions.
SECRET_KEY=REPLACE_WITH_GENERATED_TOKEN_HEX_32

# [OPTIONAL] JWT signing algorithm — HS256 is standard; change only if your
#            security policy mandates RS256 (requires asymmetric key setup).
ALGORITHM=HS256

# [OPTIONAL] JWT lifetime in minutes.  60 minutes suits most SOC workflows.
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── HTTP Ingest Endpoint ────────────────────────────────────────────────────────
# Static API key for machine-to-machine log ingestion (Vector, Fluent Bit, etc.)
# [REQUIRED] [GENERATE]
#   Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
INGEST_API_KEY=REPLACE_WITH_GENERATED_TOKEN_URLSAFE_48

# [OPTIONAL] HTTP header name that carrying agents must set.
INGEST_API_KEY_HEADER=X-Atlas-API-Key

# [OPTIONAL] Maximum log events accepted in a single POST request.
INGEST_MAX_BATCH_SIZE=5000


# ── Wazuh Manager API ──────────────────────────────────────────────────────────
# [REQUIRED] Full base URL of your Wazuh Manager REST API.
#   Example: https://192.168.1.100:55000
WAZUH_API_URL=https://REPLACE_WITH_WAZUH_MANAGER_IP:55000

# [REQUIRED] Wazuh API username.  The wazuh-wui account is created by default.
WAZUH_USERNAME=wazuh-wui

# [REQUIRED] Password for the Wazuh API user above.
WAZUH_PASSWORD=REPLACE_WITH_WAZUH_API_PASSWORD

# [OPTIONAL] Set to true and supply WAZUH_CA_BUNDLE to enable TLS certificate
#            verification.  Leave false only for self-signed lab certificates.
WAZUH_VERIFY_SSL=false

# [OPTIONAL] Absolute path to the Wazuh CA bundle PEM file.
#            Used only when WAZUH_VERIFY_SSL=true.
#   Example: /etc/wazuh-certs/ca.pem
WAZUH_CA_BUNDLE=


# ── Velociraptor Webhook ────────────────────────────────────────────────────────
# [REQUIRED] [GENERATE] HMAC-SHA256 shared secret used to verify that webhook
#            payloads genuinely originate from your Velociraptor server.
#   Generate: openssl rand -hex 32
VELOCIRAPTOR_WEBHOOK_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32

# [OPTIONAL] Base URL of the Velociraptor API server.  Leave blank if not used.
VELOCIRAPTOR_API_URL=

# [OPTIONAL] API key / certificate for Velociraptor API calls.  Leave blank if not used.
VELOCIRAPTOR_API_KEY=


# ── CORS ────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated list of allowed frontend origins.
#            Used only when DEBUG=false.  Wildcards are allowed in debug mode.
#   Example: http://localhost:3000,https://soc.yourcompany.com
ALLOWED_CORS_ORIGINS=http://localhost:3000


# ── Startup Sequence Flags ──────────────────────────────────────────────────────
# [OPTIONAL] Seed incidents and alerts from JSONL files on startup.
#            true  — dev / first-boot: useful for populating a fresh database.
#            false — production: rely on Vector/Fluent Bit hot-path; skip re-ingest.
STARTUP_RUN_LOG_INGEST=true

# [OPTIONAL] Pre-load Loghub CSVs into Pandas on startup.
#            true  — normal operation.
#            false — CI / unit tests that have no CSV files mounted.
STARTUP_WARM_PANDAS_CACHE=true


# ── Log Ingestion ──────────────────────────────────────────────────────────────
# [OPTIONAL] Relative or absolute path to the directory containing JSONL / CSV files.
LOG_DATA_DIR=data/logs


# ── Ollama LLM Copilot (optional) ─────────────────────────────────────────────
# [OPTIONAL] Leave at defaults if you are not running a local Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# ── Risk & Anomaly Thresholds ──────────────────────────────────────────────────
# [OPTIONAL] Tune to match your environment's baseline noise level.
RISK_WARN_THRESHOLD=1
RISK_SOFT_LIMIT_THRESHOLD=3
RISK_HARD_BLOCK_THRESHOLD=5
ANOMALY_SCORE_THRESHOLD=-0.1


# ── AWS S3 Cold-Storage Ingestion ──────────────────────────────────────────────
# [OPTIONAL] Set S3_ENABLED=true to start the background S3 polling task.
S3_ENABLED=false

# [OPTIONAL] Leave blank to use the IAM role / instance profile attached to your
#            compute instance (recommended for production on EC2 / ECS / EKS).
#            Only set explicitly for local dev or cross-account scenarios.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# [OPTIONAL] S3 bucket and prefix where cold-storage logs are written.
S3_LOG_BUCKET=atlas-soc-cold-logs
S3_LOG_PREFIX=logs/

# [OPTIONAL] How often the background task polls for new S3 objects (seconds).
S3_POLL_INTERVAL_SECONDS=300

# [OPTIONAL] Maximum S3 objects downloaded per poll cycle.
S3_MAX_KEYS_PER_POLL=50
