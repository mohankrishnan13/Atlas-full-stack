# ══════════════════════════════════════════════════════════════════════════════
# ATLAS SOC Dashboard — Environment Configuration Template
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every line marked [REQUIRED].
# 3. NEVER commit .env to version control — it's already in .gitignore.
#
# Legend
# ──────
#   [REQUIRED]  App will refuse to start without a real value.
#   [OPTIONAL]  A safe default exists; override only when needed.
#   [GENERATE]  Must be generated — do not invent a value manually.
#
# One-shot secret generation (run in your terminal):
#   python -c "
#   import secrets
#   print('SECRET_KEY='        + secrets.token_hex(32))
#   print('INGEST_API_KEY='    + secrets.token_urlsafe(48))
#   "
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ────────────────────────────────────────────────────────────────

# [OPTIONAL] Human-readable service name shown in logs and the /health endpoint.
APP_NAME=ATLAS

# [OPTIONAL] Runtime environment label — controls log verbosity and error detail.
#   Allowed: development | staging | production
APP_ENV=development

# [OPTIONAL] Full exception detail in HTTP 500 responses.
#            Always set to false in production.
DEBUG=true


# ── PostgreSQL ─────────────────────────────────────────────────────────────────

# [REQUIRED] Async SQLAlchemy URL — consumed by all FastAPI route handlers.
#   Format:  postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#   Docker Compose default points to the 'postgres' service defined in compose.
DATABASE_URL=postgresql+asyncpg://atlas_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/atlas_db

# [OPTIONAL] Sync URL — consumed only by Alembic CLI migrations, not at runtime.
#            Leave blank if you are not running Alembic migrations locally.
DATABASE_URL_SYNC=postgresql+psycopg2://atlas_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/atlas_db

# [OPTIONAL] Connection pool tuning — safe defaults suit most deployments.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# [OPTIONAL] Log every SQL statement to stdout — enable only for deep debugging.
DB_ECHO_SQL=false


# ── PostgreSQL Container (Docker Compose) ──────────────────────────────────────

# [REQUIRED] Credentials for the 'postgres' Docker Compose service.
#            Must exactly match the user/password embedded in DATABASE_URL above.
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=atlas_db


# ── Seed / Bootstrap Accounts ──────────────────────────────────────────────────

# Three role-separated accounts are created automatically on the very first boot
# when the atlas_users table is empty.
#
# ⚠️  Change ALL seed passwords before the first boot.
#     After first boot, the hashed values are stored in the database; updating
#     .env will NOT change existing passwords — use the UI to rotate them.

# [OPTIONAL] Login email for each seeded account.
SEED_ADMIN_EMAIL=admin@atlas.local
SEED_ANALYST_EMAIL=analyst@atlas.local
SEED_READONLY_EMAIL=audit@atlas.local

# [REQUIRED] Password for the Admin account (role: Admin).
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD

# [REQUIRED] Password for the SOC Analyst account (role: Analyst).
SEED_ANALYST_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD

# [REQUIRED] Password for the read-only auditor account (role: Read-Only).
SEED_READONLY_PASSWORD=REPLACE_WITH_STRONG_UNIQUE_PASSWORD

# [OPTIONAL] Display name for each seeded account.
SEED_ADMIN_NAME=ATLAS Administrator
SEED_ANALYST_NAME=SOC Analyst
SEED_READONLY_NAME=External Auditor


# ── JWT Security ───────────────────────────────────────────────────────────────

# [REQUIRED] [GENERATE] Secret used to sign and verify all JWT access tokens.
#   Generate: python -c "import secrets; print(secrets.token_hex(32))"
#   Rotating this key immediately invalidates all active user sessions.
SECRET_KEY=REPLACE_WITH_GENERATED_TOKEN_HEX_32

# [OPTIONAL] JWT signing algorithm — HS256 is the standard.
#            Change to RS256 only if your policy mandates asymmetric keys
#            (requires separate public/private key configuration).
ALGORITHM=HS256

# [OPTIONAL] JWT lifetime in minutes.  60 minutes is recommended for SOC use.
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── HTTP Log Ingest ────────────────────────────────────────────────────────────

# Static API key for machine-to-machine log ingestion from agents such as
# Vector, Fluent Bit, or Logstash.  Verified via HMAC compare_digest.
#
# [REQUIRED] [GENERATE]
#   Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
INGEST_API_KEY=REPLACE_WITH_GENERATED_TOKEN_URLSAFE_48

# [OPTIONAL] HTTP request header name that agents must include the key in.
INGEST_API_KEY_HEADER=X-Atlas-API-Key

# [OPTIONAL] Maximum number of log events accepted in a single POST request.
INGEST_MAX_BATCH_SIZE=5000


# ── Wazuh Manager API ──────────────────────────────────────────────────────────

# Used by WazuhActions (core/wazuh_client.py) to execute active-response
# commands (host-deny, firewall-drop, restart-wazuh) and by WazuhCollector
# (services/wazuh_service.py) to sync alerts every 60 seconds.

# [REQUIRED] Full base URL of the Wazuh Manager REST API.
#   Example: https://192.168.1.100:55000
WAZUH_API_URL=https://REPLACE_WITH_WAZUH_MANAGER_IP:55000

# [REQUIRED] Wazuh API username.  The 'wazuh-wui' account is created by default.
WAZUH_USERNAME=wazuh-wui

# [REQUIRED] Password for the Wazuh API user.
WAZUH_PASSWORD=REPLACE_WITH_WAZUH_API_PASSWORD

# [OPTIONAL] Enable TLS certificate verification for Wazuh Manager connections.
#            Set to true and supply WAZUH_CA_BUNDLE in production.
WAZUH_VERIFY_SSL=false

# [OPTIONAL] Absolute path to the Wazuh Manager CA bundle PEM file.
#            Required only when WAZUH_VERIFY_SSL=true.
#   Example: /etc/wazuh-certs/ca.pem
WAZUH_CA_BUNDLE=


# ── Wazuh Indexer (OpenSearch / Alerts Storage) ────────────────────────────────

# The Wazuh Indexer stores raw alert documents.  ATLAS queries it at
# wazuh-alerts-* to sync the latest endpoint security events.

# [REQUIRED] Full base URL of the Wazuh Indexer REST API.
#   Example: https://192.168.1.100:9200
WAZUH_INDEXER_URL=https://REPLACE_WITH_WAZUH_INDEXER_IP:9200

# [REQUIRED] Wazuh Indexer username.
WAZUH_INDEXER_USERNAME=admin

# [REQUIRED] Wazuh Indexer password.
WAZUH_INDEXER_PASSWORD=REPLACE_WITH_WAZUH_INDEXER_PASSWORD

# [OPTIONAL] Enable TLS certificate verification for Indexer connections.
WAZUH_INDEXER_VERIFY_SSL=false

# [OPTIONAL] Absolute path to the Indexer CA bundle PEM file.
WAZUH_INDEXER_CA_BUNDLE=


# ── CORS ────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated list of allowed frontend origins.
#            Ignored in debug mode (wildcard '*' is used automatically).
#   Example: http://localhost:3000,https://soc.yourcompany.com
ALLOWED_CORS_ORIGINS=http://localhost:3000


# ── Ollama LLM Copilot (Optional) ─────────────────────────────────────────────

# [OPTIONAL] URL of your local Ollama instance.
#            Leave at default if you are not running Ollama.
OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Ollama model to use for the AI threat narrative and copilot features.
#   Examples: llama3 | mistral | gemma2
OLLAMA_MODEL=llama3


# ── Risk & Anomaly Scoring Thresholds ─────────────────────────────────────────

# [OPTIONAL] Alert level at which a warning is surfaced in the dashboard.
RISK_WARN_THRESHOLD=1

# [OPTIONAL] Alert level that triggers a soft rate-limit response.
RISK_SOFT_LIMIT_THRESHOLD=3

# [OPTIONAL] Alert level that triggers an automatic hard block.
RISK_HARD_BLOCK_THRESHOLD=5

# [OPTIONAL] IsolationForest anomaly score below which a log event is flagged.
#            Negative values are anomalous (sklearn convention).
ANOMALY_SCORE_THRESHOLD=-0.1


# ── AWS S3 Cold-Storage Ingestion (Optional) ───────────────────────────────────

# [OPTIONAL] Set to true to start the background S3 polling task.
#            Requires valid AWS credentials or an attached IAM role.
S3_ENABLED=false

# [OPTIONAL] Explicit AWS credentials.
#            Leave blank to use the IAM role / instance profile (recommended
#            for EC2, ECS, or EKS deployments — never hardcode keys in prod).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# [OPTIONAL] S3 bucket and key prefix where cold-storage logs are archived.
S3_LOG_BUCKET=atlas-soc-cold-logs
S3_LOG_PREFIX=logs/

# [OPTIONAL] Polling interval in seconds for the S3 background task.
S3_POLL_INTERVAL_SECONDS=300

# [OPTIONAL] Maximum number of S3 objects downloaded per poll cycle.
S3_MAX_KEYS_PER_POLL=50


# ── Log Storage ────────────────────────────────────────────────────────────────

# [OPTIONAL] Relative or absolute path to the directory containing
#            JSONL log files and Loghub CSV datasets.
#            Relative paths are resolved from the project root.
LOG_DATA_DIR=data/logs
