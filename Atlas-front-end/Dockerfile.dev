# ═══════════════════════════════════════════════════════════════════════
# ATLAS Frontend — Development Dockerfile
#
# Features
#   • Next.js hot reload
#   • No rebuild on code change
#   • Faster startup
#   • Works with docker compose volume mount
# ═══════════════════════════════════════════════════════════════════════

FROM node:20-alpine

WORKDIR /app

# Install dependencies first for caching
COPY package.json package-lock.json* ./

RUN npm install

# Copy project
COPY . .

# Disable telemetry
ENV NEXT_TELEMETRY_DISABLED=1

EXPOSE 3000

# Start Next.js dev server
CMD ["npm", "run", "dev"]